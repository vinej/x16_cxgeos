    ldy #(.len)
    lda #<(.name)
    ldx #>(.name)
    jsr cx_bload
}
!macro cxm_dir_open .pat, .len {                ; open the directory channel -> carry = DOS error
    ldy #(.len)
    lda #<(.pat)
    ldx #>(.pat)
    jsr cx_dir_open
}
!macro cxm_dir_next .buf {                ; P0/1 = a >=17-byte buffer -> A=0 file/1 dir, carry=done
    +cxpw16 X16_P0, .buf
    jsr cx_dir_next
}
!macro cxm_dir_close {
    jsr cx_dir_close
}
!macro cxm_dos_cmd .cmd, .len {                ; A/X = a CMDR-DOS command -> A = status (>=20 = error)
    ldy #(.len)
    lda #<(.cmd)
    ldx #>(.cmd)
    jsr cx_dos_cmd
}
!macro cxm_dos_msg .buf {                ; P0/1 = a >=64-byte buffer -> A = reply length
    +cxpw16 X16_P0, .buf
    jsr cx_dos_msg
}
!macro cxm_clip_put .type, .src, .len {                ; A = type, P0/1 = src, P2/3 = len -> carry = too big
    +cxpw16 X16_P0, .src
    +cxpw16 X16_P2, .len
    lda #(.type)
    jsr cx_clip_put
}
!macro cxm_clip_get .dst, .cap {                ; P0/1 = dst, P2/3 = cap -> A = type, P2/3 = length copied
    +cxpw16 X16_P0, .dst
    +cxpw16 X16_P2, .cap
    jsr cx_clip_get
}
!macro cxm_clip_type {                ; -> A = the type waiting (0 = empty), P2/3 = length
    jsr cx_clip_type
}
!macro cxm_font_draw .str, .x0, .y0 {                ; the 1:1 slot name; = cxm_say
    +cxm_say .str, .x0, .y0
}

; =====================================================================
; descriptor builders -- the byte layouts of docs/formats.md
; =====================================================================
!macro cxm_wg_button .x0, .y0, .w0, .h0, .label {                ; a push button
    !byte CX_WG_BUTTON, 0
    !word .x0, .y0, .w0
    !byte .h0, 0, 0
    !word .label
    !byte 0, 0, 0
}
!macro cxm_wg_check .x0, .y0, .w0, .h0, .on, .label {                ; on = 1 checked
    !byte CX_WG_CHECK, 0
    !word .x0, .y0, .w0
    !byte .h0, .on, 0
    !word .label
    !byte 0, 0, 0
}
!macro cxm_wg_radio .x0, .y0, .w0, .h0, .on, .group, .label {
    !byte CX_WG_RADIO, 0
    !word .x0, .y0, .w0
    !byte .h0, .on, .group
    !word .label
    !byte 0, 0, 0
}
!macro cxm_wg_scroll .x0, .y0, .w0, .h0, .val, .max {                ; value 0..max inclusive
    !byte CX_WG_SCROLL, 0
    !word .x0, .y0, .w0
    !byte .h0, .val, .max
    !word 0
    !byte 0, 0, 0
}
!macro cxm_wg_field .x0, .y0, .w0, .h0, .cap, .buf {                ; buf = a NUL-terminated edit buffer
    !byte CX_WG_FIELD, 0
    !word .x0, .y0, .w0
    !byte .h0, 0, .cap
    !word .buf
    !byte 0, 0, 0
}
!macro cxm_wg_list .x0, .y0, .w0, .h0, .count, .ptrs {                ; ptrs = a list of string pointers
    !byte CX_WG_LIST, 0
    !word .x0, .y0, .w0
    !byte .h0, 0, .count
    !word .ptrs
    !byte 0, 0, 0
}
!macro cxm_wg_icon .x0, .y0, .w0, .h0, .id, .label {                ; a 24x24 icon; id = CX_ICON_*
    !byte CX_WG_ICON, 0
    !word .x0, .y0, .w0
    !byte .h0, .id, 0
    !word .label
    !byte 0, 0, 0
}
!macro cxm_wg_hit .x0, .y0, .w0, .h0, .shape, .trig {                ; an invisible hit region the app draws
    !byte CX_WG_HIT, 0
    !word .x0, .y0, .w0
    !byte .h0, .shape, .trig
    !word 0
    !byte 0, 0, 0
}
!macro cxm_wcount .first, .last {                ; a widget list's leading count, from the record span
    !byte (.last - .first - 1) / CX_WG_SIZE
}
!macro cxm_menu_bar .nmenus {                ; a menu bar: a count, then (title, items) per menu
    !byte .nmenus
}
!macro cxm_menu .title, .items {                ; one bar entry
    !word .title, .items
}
!macro cxm_items .nitems {                ; one menu's drop-down: a count, then a label per item
    !byte .nitems
}
!macro cxm_item .label {                ; one item / button label
    !word .label
}
!macro cxm_dialog .nbuttons, .msg {                ; an alert descriptor; buttons follow with cxm_item
    !byte .nbuttons
    !word .msg
}
!macro cxm_panel_hdr .x0, .y0, .w0, .h0, .title, .wlist, .nbuttons {                ; a modal panel header; buttons follow with cxm_item
    !word .x0, .y0, .w0
    !byte .h0
    !word .title
    !word .wlist
    !byte .nbuttons
}
!macro cxm_theme_rec .c0, .c1, .c2, .c3, .paper, .hi, .frame {                ; a 12-byte theme: four $0RGB colours, then paper/hi/frame roles
    !byte <(.c0), >(.c0)
    !byte <(.c1), >(.c1)
    !byte <(.c2), >(.c2)
    !byte <(.c3), >(.c3)
    !byte .paper, .hi, .frame, 0
}
