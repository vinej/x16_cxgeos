    macro cxm_dos_msg                ; P0/1 = a >=64-byte buffer -> A = reply length
    cxpw16 X16_P0, \1
    jsr cx_dos_msg
    endm
    macro cxm_clip_put                ; A = type, P0/1 = src, P2/3 = len -> carry = too big
    cxpw16 X16_P0, \2
    cxpw16 X16_P2, \3
    lda #(\1)
    jsr cx_clip_put
    endm
    macro cxm_clip_get                ; P0/1 = dst, P2/3 = cap -> A = type, P2/3 = length copied
    cxpw16 X16_P0, \1
    cxpw16 X16_P2, \2
    jsr cx_clip_get
    endm
    macro cxm_clip_type                ; -> A = the type waiting (0 = empty), P2/3 = length
    jsr cx_clip_type
    endm
    macro cxm_font_draw                ; the 1:1 slot name; = cxm_say
    cxm_say \1, \2, \3
    endm

; =====================================================================
; descriptor builders -- the byte layouts of docs/formats.md
; =====================================================================
    macro cxm_wg_button                ; a push button
    byte CX_WG_BUTTON, 0
    word \1, \2, \3
    byte \4, 0, 0
    word \5
    byte 0, 0, 0
    endm
    macro cxm_wg_check                ; on = 1 checked
    byte CX_WG_CHECK, 0
    word \1, \2, \3
    byte \4, \5, 0
    word \6
    byte 0, 0, 0
    endm
    macro cxm_wg_radio
    byte CX_WG_RADIO, 0
    word \1, \2, \3
    byte \4, \5, \6
    word \7
    byte 0, 0, 0
    endm
    macro cxm_wg_scroll                ; value 0..max inclusive
    byte CX_WG_SCROLL, 0
    word \1, \2, \3
    byte \4, \5, \6
    word 0
    byte 0, 0, 0
    endm
    macro cxm_wg_field                ; buf = a NUL-terminated edit buffer
    byte CX_WG_FIELD, 0
    word \1, \2, \3
    byte \4, 0, \5
    word \6
    byte 0, 0, 0
    endm
    macro cxm_wg_list                ; ptrs = a list of string pointers
    byte CX_WG_LIST, 0
    word \1, \2, \3
    byte \4, 0, \5
    word \6
    byte 0, 0, 0
    endm
    macro cxm_wg_list2                ; two-column list: sizes = a parallel array of size-string pointers, drawn right-aligned (null = no size that row)
    byte CX_WG_LIST, 0
    word \1, \2, \3
    byte \4, 0, \5
    word \6
    byte 0
    word \7
    endm
    macro cxm_wg_icon                ; a 24x24 icon; id = CX_ICON_*
    byte CX_WG_ICON, 0
    word \1, \2, \3
    byte \4, \5, 0
    word \6
    byte 0, 0, 0
    endm
    macro cxm_wg_hit                ; an invisible hit region the app draws
    byte CX_WG_HIT, 0
    word \1, \2, \3
    byte \4, \5, \6
    word 0
    byte 0, 0, 0
    endm
    macro cxm_wg_hit_poly                ; a hit region: a regular n-gon (square box)
    byte CX_WG_HIT, 0
    word \1, \2, \3
    byte \4, CX_WH_POLYGON, \7
    word 0
    byte \5, \6, 0
    endm
    macro cxm_wg_hit_pie                ; a hit region: an arc/pie wedge (square box)
    byte CX_WG_HIT, 0
    word \1, \2, \3
    byte \4, CX_WH_PIE, \7
    word 0
    byte \5, \6, 0
    endm
    macro cxm_wcount                ; a widget list's leading count, from the record span
    byte (\2 - \1 - 1) / CX_WG_SIZE
    endm
    macro cxm_menu_bar                ; a menu bar: a count, then (title, items) per menu
    byte \1
    endm
    macro cxm_menu                ; one bar entry
    word \1, \2
    endm
    macro cxm_items                ; one menu's drop-down: a count, then a label per item
    byte \1
    endm
    macro cxm_item                ; one item / button label
    word \1
    endm
    macro cxm_dialog                ; an alert descriptor; buttons follow with cxm_item
    byte \1
    word \2
    endm
    macro cxm_panel_hdr                ; a modal panel header; buttons follow with cxm_item
    word \1, \2, \3
    byte \4
    word \5
    word \6
    byte \7
    endm
    macro cxm_theme_rec                ; a 12-byte theme: four $0RGB colours, then paper/hi/frame roles
    byte <(\1), >(\1)
    byte <(\2), >(\2)
    byte <(\3), >(\3)
    byte <(\4), >(\4)
    byte \5, \6, \7, 0
    endm
