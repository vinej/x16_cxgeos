    jsr cx_dir_close
    ENDM
    MAC cxm_dos_cmd                ; A/X = a CMDR-DOS command -> A = status (>=20 = error)
    ldy #({2})
    lda #<({1})
    ldx #>({1})
    jsr cx_dos_cmd
    ENDM
    MAC cxm_dos_msg                ; P0/1 = a >=64-byte buffer -> A = reply length
    cxpw16 X16_P0, {1}
    jsr cx_dos_msg
    ENDM
    MAC cxm_clip_put                ; A = type, P0/1 = src, P2/3 = len -> carry = too big
    cxpw16 X16_P0, {2}
    cxpw16 X16_P2, {3}
    lda #({1})
    jsr cx_clip_put
    ENDM
    MAC cxm_clip_get                ; P0/1 = dst, P2/3 = cap -> A = type, P2/3 = length copied
    cxpw16 X16_P0, {1}
    cxpw16 X16_P2, {2}
    jsr cx_clip_get
    ENDM
    MAC cxm_clip_type                ; -> A = the type waiting (0 = empty), P2/3 = length
    jsr cx_clip_type
    ENDM
    MAC cxm_font_draw                ; the 1:1 slot name; = cxm_say
    cxm_say {1}, {2}, {3}
    ENDM

; =====================================================================
; descriptor builders -- the byte layouts of docs/formats.md
; =====================================================================
    MAC cxm_wg_button                ; a push button
    dc.b CX_WG_BUTTON, 0
    dc.w {1}, {2}, {3}
    dc.b {4}, 0, 0
    dc.w {5}
    dc.b 0, 0, 0
    ENDM
    MAC cxm_wg_check                ; on = 1 checked
    dc.b CX_WG_CHECK, 0
    dc.w {1}, {2}, {3}
    dc.b {4}, {5}, 0
    dc.w {6}
    dc.b 0, 0, 0
    ENDM
    MAC cxm_wg_radio
    dc.b CX_WG_RADIO, 0
    dc.w {1}, {2}, {3}
    dc.b {4}, {5}, {6}
    dc.w {7}
    dc.b 0, 0, 0
    ENDM
    MAC cxm_wg_scroll                ; value 0..max inclusive
    dc.b CX_WG_SCROLL, 0
    dc.w {1}, {2}, {3}
    dc.b {4}, {5}, {6}
    dc.w 0
    dc.b 0, 0, 0
    ENDM
    MAC cxm_wg_field                ; buf = a NUL-terminated edit buffer
    dc.b CX_WG_FIELD, 0
    dc.w {1}, {2}, {3}
    dc.b {4}, 0, {5}
    dc.w {6}
    dc.b 0, 0, 0
    ENDM
    MAC cxm_wg_list                ; ptrs = a list of string pointers
    dc.b CX_WG_LIST, 0
    dc.w {1}, {2}, {3}
    dc.b {4}, 0, {5}
    dc.w {6}
    dc.b 0, 0, 0
    ENDM
    MAC cxm_wg_icon                ; a 24x24 icon; id = CX_ICON_*
    dc.b CX_WG_ICON, 0
    dc.w {1}, {2}, {3}
    dc.b {4}, {5}, 0
    dc.w {6}
    dc.b 0, 0, 0
    ENDM
    MAC cxm_wg_hit                ; an invisible hit region the app draws
    dc.b CX_WG_HIT, 0
    dc.w {1}, {2}, {3}
    dc.b {4}, {5}, {6}
    dc.w 0
    dc.b 0, 0, 0
    ENDM
    MAC cxm_wg_hit_poly                ; a hit region: a regular n-gon (square box)
    dc.b CX_WG_HIT, 0
    dc.w {1}, {2}, {3}
    dc.b {4}, CX_WH_POLYGON, {7}
    dc.w 0
    dc.b {5}, {6}, 0
    ENDM
    MAC cxm_wg_hit_pie                ; a hit region: an arc/pie wedge (square box)
    dc.b CX_WG_HIT, 0
    dc.w {1}, {2}, {3}
    dc.b {4}, CX_WH_PIE, {7}
    dc.w 0
    dc.b {5}, {6}, 0
    ENDM
    MAC cxm_wcount                ; a widget list's leading count, from the record span
    dc.b ({2} - {1} - 1) / CX_WG_SIZE
    ENDM
    MAC cxm_menu_bar                ; a menu bar: a count, then (title, items) per menu
    dc.b {1}
    ENDM
    MAC cxm_menu                ; one bar entry
    dc.w {1}, {2}
    ENDM
    MAC cxm_items                ; one menu's drop-down: a count, then a label per item
    dc.b {1}
    ENDM
    MAC cxm_item                ; one item / button label
    dc.w {1}
    ENDM
    MAC cxm_dialog                ; an alert descriptor; buttons follow with cxm_item
    dc.b {1}
    dc.w {2}
    ENDM
    MAC cxm_panel_hdr                ; a modal panel header; buttons follow with cxm_item
    dc.w {1}, {2}, {3}
    dc.b {4}
    dc.w {5}
    dc.w {6}
    dc.b {7}
    ENDM
    MAC cxm_theme_rec                ; a 12-byte theme: four $0RGB colours, then paper/hi/frame roles
    dc.b <({1}), >({1})
    dc.b <({2}), >({2})
    dc.b <({3}), >({3})
    dc.b <({4}), >({4})
    dc.b {5}, {6}, {7}, 0
    ENDM
